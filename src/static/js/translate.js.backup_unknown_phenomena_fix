        'Join us on this journey through time as we uncover the secrets of the past.': '加入我们，一起踏上穿越时间的旅程，揭开过去的秘密。',
        'Back to Categories': '返回分类',
        
        // Chinese to English (for Chinese pages)
        '首页': 'Home',
        '关于我们': 'About',
        '神秘历史': 'Mystery History',
        '探索故事': 'Explore Stories',
        '古代之谜': 'Ancient Mysteries',
        '来自古代的难解之谜': 'Enigmas from antiquity that defy explanation',
        '趣味历史': 'Interesting History',
        '世界历史中鲜为人知的精彩故事': 'Fascinating lesser-known stories from world history',
        '未解之谜': 'Unknown Phenomena',
        '不明飞行物、超自然现象和未解之谜': 'UFOs, paranormal events, and unexplained mysteries',
        '版权所有。': 'All rights reserved.',
        '关于神秘历史': 'About Mystery History',
        '欢迎来到神秘历史，这里是通往世界上最迷人的未解之谜和被遗忘故事的入口。': 'Welcome to Mystery History, your gateway to the world\'s most fascinating unsolved mysteries and forgotten tales from the past.',
        '我们的使命': 'Our Mission',
        '我们致力于为您带来经过深入研究的、引人入胜的历史谜团故事。': 'We are dedicated to bringing you well-researched, engaging stories about historical mysteries that continue to captivate and puzzle us.',
        '我们的内容': 'What We Cover',
        '加入我们，一起踏上穿越时间的旅程，揭开过去的秘密。': 'Join us on this journey through time as we uncover the secrets of the past.',
        '返回分类': 'Back to Categories'
    };

    // Current language state
    let currentLang = localStorage.getItem('preferredLanguage') || 'en';

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
        // Apply saved language preference
        if (currentLang === 'zh') {
            applyTranslations();
            updateToggleButton();
        }
    });

    // Toggle language function (called by button)
    window.toggleLanguage = function() {
        currentLang = currentLang === 'en' ? 'zh' : 'en';
        localStorage.setItem('preferredLanguage', currentLang);
        
        if (currentLang === 'zh') {
            applyTranslations();
        } else {
            restoreEnglish();
        }
        updateToggleButton();
        
        // Log for debugging
        console.log('Language toggled to:', currentLang);
    };

    function applyTranslations() {
        let translatedCount = 0;
        // Find all elements with data-translate attribute
        document.querySelectorAll('[data-translate]').forEach(function(el) {
            const key = el.getAttribute('data-translate');
            if (translations[key]) {
                // Store original text if not already stored
                if (!el.getAttribute('data-original')) {
                    el.setAttribute('data-original', el.textContent.trim());
                }
                el.textContent = translations[key];
                translatedCount++;
            } else {
                console.warn('No translation found for key:', key);
            }
        });
        
        // Also update page title if it contains translatable content
        updatePageTitle();
        
        console.log('Applied translations to', translatedCount, 'elements');
    }

    function restoreEnglish() {
        let restoredCount = 0;
        document.querySelectorAll('[data-translate]').forEach(function(el) {
            const original = el.getAttribute('data-original');
            if (original) {
                el.textContent = original;
                restoredCount++;
            }
        });
        
        // Restore page title
        restorePageTitle();
        
        console.log('Restored English for', restoredCount, 'elements');
    }

    function updateToggleButton() {
        const btn = document.getElementById('langToggle');
        if (btn) {
            btn.textContent = currentLang === 'en' ? 'EN | 中文' : 'EN | 中文';
            btn.title = currentLang === 'en' ? 'Switch to Chinese' : '切换到英文';
        }
    }

    function updatePageTitle() {
        const titleElement = document.querySelector('title');
        if (titleElement && translations[titleElement.textContent]) {
            titleElement.textContent = translations[titleElement.textContent];
        }
    }

    function restorePageTitle() {
        // Page titles are handled by data-original on the title element if needed
        // For now, we focus on body content translation
    }
})();
